# Copy to .env and fill in. .env is gitignored.

# --- LLM (production responder) ---
ANTHROPIC_API_KEY=sk-ant-...
# Claude Haiku 4.5 — $1/$5 per 1M tokens. (scoping.md still names 3.5 Sonnet.)
LLM_MODEL=claude-haiku-4-5

# --- Embeddings + cross-model judge ---
OPENAI_API_KEY=sk-...
# Pinned per scoping.md (risk #8: changing this requires a full re-embed).
EMBED_MODEL=text-embedding-3-small

# --- Vector store (matches infra/docker-compose.yml) ---
DATABASE_URL=postgresql://payments:payments@127.0.0.1:5433/payments_rag
